Experiment No.—4 : Android Layouts, UI Controls, and Event Handling 

To design an app using various layouts and UI controls with event handling, validation, and styled 
themes. 


import 'package:flutter/material.dart'; 
 
void main() { 
  runApp(MyApp()); 
} 
 
class MyApp extends StatelessWidget { 
  @override 
  Widget build(BuildContext context) { 
    return MaterialApp( 
      title: 'Flutter UI Demo', 
      debugShowCheckedModeBanner: false, 
      theme: ThemeData( 
        primarySwatch: Colors.teal, 
        inputDecorationTheme: InputDecorationTheme( 
          border: OutlineInputBorder(), 
          filled: true, 
          fillColor: Colors.white, 
        ), 
        textTheme: TextTheme( 
          titleLarge: TextStyle(fontSize: 22, fontWeight: 
FontWeight.bold), 
          bodyMedium: TextStyle(fontSize: 16), 
        ), 
      ), 
      home: HomeScreen(), 
    ); 
  } 
} 
 
class HomeScreen extends StatefulWidget { 
  @override 
  State<HomeScreen> createState() => _HomeScreenState(); 
} 
class _HomeScreenState extends State<HomeScreen> { 
  // Form key & controllers 
  final _formKey = GlobalKey<FormState>(); 
  final TextEditingController nameController = 
TextEditingController(); 
 
  // States 
  bool notifications = false; 
  double volume = 50; 
  String selectedCity = "Select City"; 
  bool agree = false; 
 
  @override 
  Widget build(BuildContext context) { 
    return Scaffold( 
      appBar: AppBar( 
        title: Text('Flutter Layout & Controls'), 
      ), 
      body: ListView( 
        padding: EdgeInsets.all(16), 
        children: [ 
          Text("User Form", style: 
Theme.of(context).textTheme.titleLarge), 
 
          SizedBox(height: 15), 
 
          // Form with validation 
          Form( 
            key: _formKey, 
            child: Column( 
              children: [ 
                TextFormField( 
                  controller: nameController, 
                  decoration: InputDecoration(labelText: "Name"), 
                  validator: (value) { 
                    if (value == null || value.isEmpty) { 
                      return "Name cannot be empty"; 
  } 
                    return null; 
                  }, 
                ), 
                SizedBox(height: 15), 
              ], 
            ), 
          ), 
 
          // Dropdown 
          DropdownButtonFormField<String>( 
            value: selectedCity == "Select City" ? null : 
selectedCity, 
            hint: Text("Select City"), 
            items: ["Delhi", "Mumbai", "Chennai", "Bangalore"] 
                .map((city) => DropdownMenuItem(value: city, child: 
Text(city))) 
                .toList(), 
            onChanged: (value) { 
              setState(() => selectedCity = value!); 
            }, 
          ), 
 
          SizedBox(height: 20), 
 
          // Switch 
          SwitchListTile( 
            title: Text("Enable Notifications"), 
            value: notifications, 
            onChanged: (value) { 
              setState(() => notifications = value); 
            }, 
          ), 
 
          // Slider 
          Column( 
            crossAxisAlignment: CrossAxisAlignment.start, 
 children: [ 
              Text("Volume: ${volume.toInt()}"), 
              Slider( 
                value: volume, 
                min: 0, 
                max: 100, 
                onChanged: (value) { 
                  setState(() => volume = value); 
                }, 
              ), 
            ], 
          ), 
 
          // Checkbox 
          CheckboxListTile( 
            title: Text("Agree to Terms & Conditions"), 
            value: agree, 
            onChanged: (value) { 
              setState(() => agree = value!); 
            }, 
          ), 
 
          SizedBox(height: 25), 
 
          // Submit Button 
          ElevatedButton( 
            onPressed: () { 
              if (_formKey.currentState!.validate()) { 
                if (!agree) { 
                  ScaffoldMessenger.of(context).showSnackBar( 
                    SnackBar(content: Text("Please agree to the 
terms")), 
                  ); 
                  return; 
                } 
                ScaffoldMessenger.of(context).showSnackBar( 
 SnackBar(content: Text("Form Submitted 
Successfully")), 
                ); 
              } 
            }, 
            child: Text("Submit"), 
          ), 
 
          SizedBox(height: 20), 
 
          // Stack Layout Example 
          Text("Stack Layout Example", 
              style: Theme.of(context).textTheme.titleLarge), 
          SizedBox(height: 10), 
          Container( 
            height: 150, 
            child: Stack( 
              children: [ 
                Container(color: Colors.teal.withOpacity(0.3)), 
                Positioned( 
                  bottom: 10, 
                  right: 10, 
                  child: Container( 
                    padding: EdgeInsets.all(8), 
                    color: Colors.teal, 
                    child: Text("Positioned Widget", 
                        style: TextStyle(color: Colors.white)), 
                  ), 
                ), 
              ], 
            ), 
          ), 
 
          SizedBox(height: 20), 
 
          // GridView Example 
          Text("Grid Layout Example",
 style: Theme.of(context).textTheme.titleLarge), 
          SizedBox(height: 10), 
          Container( 
            height: 200, 
            child: GridView.count( 
              crossAxisCount: 3, 
              children: List.generate( 
                6, 
                (index) => Container( 
                  margin: EdgeInsets.all(8), 
                  color: Colors.teal.shade200, 
                  child: Center(child: Text("Item ${index + 1}")), 
                ), 
              ), 
            ), 
          ), 
        ], 
      ), 
    ); 
  } 
} 


