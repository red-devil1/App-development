Experiment No.—7 : Implementation of Control Flow Statements and Functions in an Android 
Application Using Kotlin 

To implement Kotlin control flow statements and functions (if, when, loops, default and extension 
functions) in an Android app. 

import 'package:flutter/material.dart'; 
 
void main() { 
  runApp(const MyApp()); 
} 
 
/* ------------------ EXTENSION FUNCTION ------------------ */ 
extension StringExtension on String { 
  bool isEmail() { 
    return contains("@") && contains("."); 
  } 
} 
 
extension ContextExtension on BuildContext { 
  double get screenWidth => MediaQuery.of(this).size.width; 
} 
 
/* ------------------ MAIN APP ------------------ */ 
class MyApp extends StatelessWidget { 
  const MyApp({super.key}); 
 
  @override 
  Widget build(BuildContext context) { 
    return MaterialApp( 
      title: 'Flutter Control Flow Demo', 
      debugShowCheckedModeBanner: false, 
      home: const HomeScreen(), 
    ); 
  } 
} 
 
/* ------------------ HOME SCREEN ------------------ */ 
class HomeScreen extends StatelessWidget { 
  const HomeScreen({super.key}); 
  // Simple function 
  int add(int a, int b) { 
    return a + b; 
  } 
 
  // Arrow function 
  int multiply(int a, int b) => a * b; 
 
  // Default parameter 
  String greetUser(String name, {String message = "Hello"}) { 
    return "$message $name"; 
  } 
 
  // Switch case function (when alternative) 
  String getDay(int day) { 
    switch (day) { 
      case 1: 
        return "Monday"; 
      case 2: 
        return "Tuesday"; 
      case 3: 
        return "Wednesday"; 
      case 4: 
        return "Thursday"; 
      case 5: 
        return "Friday"; 
      default: 
        return "Invalid Day"; 
    } 
  } 
 
  // Loop function 
  List<String> generateNumbers() { 
    List<String> list = []; 
 
    for (int i = 1; i <= 5; i++) { 
      list.add("Number $i"); 
  } 
 
    return list; 
  } 
 
  @override 
  Widget build(BuildContext context) { 
    // If-else example 
    int age = 20; 
    String ageStatus = age >= 18 ? "Adult" : "Minor"; 
 
    // Extension function usage 
    String email = "test@email.com"; 
    bool isValidEmail = email.isEmail(); 
 
    // Loop data 
    List<String> numbers = generateNumbers(); 
 
    return Scaffold( 
      appBar: AppBar( 
        title: const Text("Flutter Control Flow"), 
        centerTitle: true, 
      ), 
      body: Padding( 
        padding: const EdgeInsets.all(16), 
        child: SingleChildScrollView( 
          child: Column( 
            crossAxisAlignment: CrossAxisAlignment.start, 
            children: [ 
              /* IF / ELSE */ 
              Text( 
                "IF / ELSE Example:", 
                style: Theme.of(context).textTheme.titleLarge, 
              ), 
              Text("Age: $age → $ageStatus"), 
              const Divider(),
     /* SWITCH */ 
              Text( 
                "SWITCH Example:", 
                style: Theme.of(context).textTheme.titleLarge, 
              ), 
              Text("Day 3 is ${getDay(3)}"), 
              const Divider(), 
 
              /* FUNCTIONS */ 
              Text( 
                "FUNCTIONS Example:", 
                style: Theme.of(context).textTheme.titleLarge, 
              ), 
              Text("Add: 5 + 3 = ${add(5, 3)}"), 
              Text("Multiply: 4 × 2 = ${multiply(4, 2)}"), 
              Text(greetUser("John")), 
              Text(greetUser("John", message: "Welcome")), 
              const Divider(), 
 
              /* EXTENSION FUNCTION */ 
              Text( 
                "EXTENSION FUNCTION:", 
                style: Theme.of(context).textTheme.titleLarge, 
              ), 
              Text("Email: $email"), 
              Text("Valid Email: $isValidEmail"), 
              const Divider(), 
 
              /* LOOP */ 
              Text( 
                "LOOP Example:", 
                style: Theme.of(context).textTheme.titleLarge, 
              ), 
              Column( 
                children: numbers.map((e) => Text(e)).toList(), 
              ), 
              const Divider(), 

