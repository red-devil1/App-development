Experiment No.—8 : Demonstration of Android Core Components Using Activities, Intents, and 
Activity Lifecycle 

To demonstrate Android core components by creating Activities, using explicit and implicit Intents, 
and observing Activity lifecycle events using log messages. 


import 'package:flutter/material.dart'; 
import 'package:flutter/widgets.dart'; 
 
void main() { 
  runApp(const MyApp()); 
} 
 
class MyApp extends StatelessWidget { 
  const MyApp({super.key}); 
 
  @override 
  Widget build(BuildContext context) { 
    return MaterialApp( 
      debugShowCheckedModeBanner: false, 
      title: 'Activity Lifecycle Demo', 
      home: const FirstActivity(), 
    ); 
  } 
} 
 
/// ------------------------------ 
/// FIRST ACTIVITY 
/// ------------------------------ 
class FirstActivity extends StatefulWidget { 
  const FirstActivity({super.key}); 
 
  @override 
  State<FirstActivity> createState() => _FirstActivityState(); 
} 
 
class _FirstActivityState extends State<FirstActivity> 
    with WidgetsBindingObserver { 
  @override 
  void initState() { 
    super.initState(); 
 WidgetsBinding.instance.addObserver(this); 
    debugPrint("FirstActivity : onCreate"); 
  } 
 
  @override 
  void didChangeDependencies() { 
    super.didChangeDependencies(); 
    debugPrint("FirstActivity : onStart"); 
  } 
 
  @override 
  void didChangeAppLifecycleState(AppLifecycleState state) { 
    if (state == AppLifecycleState.resumed) { 
      debugPrint("FirstActivity : onResume"); 
    } else if (state == AppLifecycleState.paused) { 
      debugPrint("FirstActivity : onPause"); 
    } else if (state == AppLifecycleState.detached) { 
      debugPrint("FirstActivity : onDestroy"); 
    } 
  } 
 
  @override 
  void dispose() { 
    WidgetsBinding.instance.removeObserver(this); 
    debugPrint("FirstActivity : onDestroy"); 
    super.dispose(); 
  } 
 
  /// Explicit Intent Simulation 
  void openSecondActivity() { 
    debugPrint("Explicit Intent : Opening SecondActivity"); 
    Navigator.push( 
      context, 
      MaterialPageRoute(builder: (context) => const 
SecondActivity()), 
    ); 
  } 
/// Implicit Intent Simulation 
  void openDialer() { 
    debugPrint("Implicit Intent : ACTION_DIAL (Dialer opened)"); 
  } 
 
  /// Implicit Intent Simulation 
  void openBrowser() { 
    debugPrint("Implicit Intent : ACTION_VIEW (Browser opened)"); 
  } 
 
  @override 
  Widget build(BuildContext context) { 
    return Scaffold( 
      appBar: AppBar(title: const Text("First Activity")), 
      body: Center( 
        child: Column( 
          mainAxisAlignment: MainAxisAlignment.center, 
          children: [ 
            ElevatedButton( 
              onPressed: openSecondActivity, 
              child: const Text("Explicit Intent"), 
            ), 
            const SizedBox(height: 10), 
            ElevatedButton( 
              onPressed: openDialer, 
              child: const Text("Implicit Intent - Dialer"), 
            ), 
            const SizedBox(height: 10), 
            ElevatedButton( 
              onPressed: openBrowser, 
              child: const Text("Implicit Intent - Browser"), 
            ), 
          ], 
        ), 
      ), 
    ); 
 } 
} 
 
/// ------------------------------ 
/// SECOND ACTIVITY 
/// ------------------------------ 
class SecondActivity extends StatefulWidget { 
  const SecondActivity({super.key}); 
 
  @override 
  State<SecondActivity> createState() => _SecondActivityState(); 
} 
 
class _SecondActivityState extends State<SecondActivity> { 
  @override 
  void initState() { 
    super.initState(); 
    debugPrint("SecondActivity : onCreate"); 
  } 
 
  @override 
  void dispose() { 
    debugPrint("SecondActivity : onDestroy"); 
    super.dispose(); 
  } 
 
  @override 
  Widget build(BuildContext context) { 
    return Scaffold( 
      appBar: AppBar(title: const Text("Second Activity")), 
      body: Center( 
        child: ElevatedButton( 
          onPressed: () { 
            debugPrint("SecondActivity : finish()"); 
            Navigator.pop(context); 
          }, 
          child: const Text("Go Back"), 
), 
), 
); 
} 
} 

